# Talyvor Docs — environment template.

DOCS_DATABASE_URL=postgres://docs:changeme@localhost:5432/talyvor_docs?sslmode=disable
DOCS_LISTEN_ADDR=0.0.0.0:4000
DOCS_LOG_LEVEL=info

# SEC-4 Layer 1 root of trust: the shared secret the edge gateway sends in the
# x-gateway-auth header to prove a request transited it — which is what makes the
# injected x-user-email trustworthy. Deliberately UNPREFIXED (not DOCS_*): it is the
# same secret the gateway signs for Track.
#
# REQUIRED. Docs FAIL-CLOSES at boot if this is unset or shorter than 16 chars,
# rather than run an open door. Generate a strong value in production:
#   openssl rand -hex 32
GATEWAY_AUTH_SECRET=dev-only-insecure-gateway-secret-change-me

# Single-tenant default. Phase 5 will iterate workspaces from the DB.
DOCS_DEFAULT_WORKSPACE=default

# Compose-only — sets the Postgres password used by the postgres
# service and referenced in DOCS_DATABASE_URL above.
POSTGRES_PASSWORD=changeme

# Track integration (optional). When set, /v1/embed pulls live data,
# the right panel shows backlinks, and a 15-min cost syncer rolls up
# Track issue AI spend into pages.ai_cost_usd.
DOCS_TRACK_URL=
DOCS_TRACK_API_KEY=

# Lens integration. When set, the AI slash commands + Ask AI panel
# proxy through Lens. AI features short-circuit to an "unavailable"
# state when these are empty.
DOCS_LENS_URL=http://localhost:8080
DOCS_LENS_API_KEY=

# Guest sharing — used to sign share-link tokens. Generate a strong
# value in production.
DOCS_SHARE_SECRET=change-this-in-production

# Invite + share-link base URL. Composed into the URLs surfaced to
# users so a self-hosted deploy can point at its real hostname.
DOCS_BASE_URL=http://localhost:4001
